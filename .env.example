# Base URL for the REST API backend.
# Preferred: NEXT_PUBLIC_MANTIS_API_URL
# Legacy fallbacks: NEXT_PUBLIC_SISCAV_API_URL, NEXT_PUBLIC_API_URL (see src/constants/index.ts)
# Production example: NEXT_PUBLIC_MANTIS_API_URL=https://siscav-api.onrender.com
NEXT_PUBLIC_MANTIS_API_URL=http://localhost:8000
NEXT_PUBLIC_SISCAV_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
